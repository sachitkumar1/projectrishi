# ============================================================================
#  MEMBER LOGIN — environment variables
#  Copy this file to ".env.local" (same folder) and fill in the values.
#  NEVER commit .env.local — it holds secrets. (.gitignore already excludes it.)
# ============================================================================

# A random secret used to encrypt login sessions.
# Generate one by running this in your terminal:   openssl rand -base64 32
NEXTAUTH_SECRET=

# The base URL of the site.
#   Local dev:   http://localhost:3000
#   Production:  https://your-domain.com   (set this in Vercel, not here)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (from Google Cloud Console — see MEMBER_LOGIN_SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LMS database (Supabase) — see LMS_SETUP.md ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
